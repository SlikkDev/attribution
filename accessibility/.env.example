# SMTP transport for the a11y-report route. Same variable names as the
# slikk.dev contact form — one spine across the family. Placeholders only;
# real values live in the host's deploy env, never in git.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Comma-separated recipients for accessibility reports. Read server-side only —
# the widget can never choose where reports go.
A11Y_REPORT_TO=we@slikk.dev,accessibility@slikk.dev,i@yarin.io

# Seam-period logging (SMTP_HOST unset): "true" logs full report bodies so
# nothing is lost while SMTP is provisioned. Off by default — bodies carry the
# reporter's email and assistive-tech details, which are sensitive; leave this
# unset unless you accept that exposure in your server logs.
A11Y_REPORT_LOG_BODY=
